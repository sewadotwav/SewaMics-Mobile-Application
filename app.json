{
  "expo": {
    "name": "SewaMics",
    "slug": "sewamics",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Brand/SewaMicsIcon.png",
    "scheme": "sewamics",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.sewamics.app"
    },
    "plugins": [
      "expo-font",
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.sewamics.app",
          "urlScheme": "sewamics"
        }
      ]
    ]
  }
}
