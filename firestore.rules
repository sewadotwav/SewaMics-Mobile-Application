// ============================================================
// SewaMics — Client-Side Only Firestore & Storage Security Rules
// File: firestore.rules
//
// COPY-PASTE INSTRUCTIONS:
//   Firebase Console → Firestore Database → Rules tab
//   Paste the entire content below, then click "Publish".
// ============================================================

rules_version = '2';

// ─────────────────────────────────────────────
// FIRESTORE RULES
// ─────────────────────────────────────────────
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // CORE RBAC HELPERS
    // ─────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Generic helpers for data validation
    function isNonEmptyString(field) {
      return field is string && field.size() > 0;
    }

    function isPositiveNumber(field) {
      return field is number && field >= 0;
    }

    // ─────────── USERS COLLECTION ───────────
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && isNonEmptyString(request.resource.data.uid)
        && isNonEmptyString(request.resource.data.email)
        && isNonEmptyString(request.resource.data.name)
        && request.resource.data.uid == userId;
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email;
      allow delete: if false;

      // WISHLIST SUBCOLLECTION
      match /wishlist/{itemId} {
        allow read, create, update, delete: if isOwner(userId);
      }

      // PRIVATE USER SUBCOLLECTION (2FA, etc)
      match /private/{document=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // ─────────── PRODUCTS COLLECTION ───────────
    match /products/{productId} {
      // Anyone can browse products (client-side)
      allow read: if true;
      
      // Clients cannot create or delete products directly
      allow create, delete: if false;

      // Clients can only update the stock when ordering (decrement only)
      allow update: if isAuthenticated()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock'])
        && request.resource.data.stock >= 0;
    }

    // ─────────── CARTS COLLECTION ───────────
    match /carts/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.uid == userId
        && request.resource.data.items is list
        && isPositiveNumber(request.resource.data.cartTotal)
        && isPositiveNumber(request.resource.data.itemCount);
      allow update: if isOwner(userId)
        && request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(userId);
    }

    // ─────────── ORDERS COLLECTION ───────────
    match /orders/{orderId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Clients place order with default status 'pending'
      allow create: if isAuthenticated()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && isPositiveNumber(request.resource.data.subtotal)
        && isPositiveNumber(request.resource.data.shippingFee)
        && isPositiveNumber(request.resource.data.totalAmount)
        && isNonEmptyString(request.resource.data.status)
        && isNonEmptyString(request.resource.data.paymentMethod)
        && isNonEmptyString(request.resource.data.paymentStatus)
        && request.resource.data.status == 'pending'
        && (request.resource.data.paymentStatus == 'paid' || request.resource.data.paymentStatus == 'pending');

      // Customers can update to cancel their own order before shipping
      allow update: if isAuthenticated()
        && resource.data.userId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'paymentStatus', 'cancelledAt'])
        && request.resource.data.status == 'cancelled'
        && request.resource.data.paymentStatus == 'refunded';

      allow delete: if false;
    }

    // ─────────── DEFAULT DENY ───────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ─────────────────────────────────────────────
// STORAGE RULES
// ─────────────────────────────────────────────
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
