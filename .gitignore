# ─────────────────────────────────────────────
# SewaMics — .gitignore
# ─────────────────────────────────────────────

# Environment variables — NEVER commit these
.env
.env.local
.env.*.local

# Dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# React build output
build/

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
